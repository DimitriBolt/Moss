# Oracle DB credentials for Moss scripts
#
# IMPORTANT:
# Workbook / Oracle scripts normally read ENV from:
#   %USERPROFILE%\Documents\.env
#
# You can copy this file to that location, or update the script to read project-root .env.

ORACLE_HOST=your-oracle-host
ORACLE_PORT=1521
ORACLE_SID=your-sid
ORACLE_USER=your-username
ORACLE_PASSWORD=your-password

# Optional: required when thick mode is needed (e.g., DPY-3001 / native encryption)
# Must point to folder containing oci.dll on Windows
ORACLE_CLIENT_LIB_DIR=C:\oracle\instantclient_21_18
